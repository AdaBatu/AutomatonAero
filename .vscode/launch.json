{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "stlinkgdbtarget",
            "request": "launch",
            "name": "STM32Cube: Launch ST-Link GDB Server",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "runEntry": "main",
            "imagesAndSymbols": [
                {
                    "imageFileName": "${workspaceFolder}/build/Debug/AutomatonAero.elf"
                }
            ]
        },
        {
            "type": "cortex-debug",
            "request": "launch",
            "name": "Cortex-Debug: ST-Link (Fallback)",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/AutomatonAero.elf",
            "servertype": "stlink",
            "device": "STM32L476RG",
            "interface": "swd",
            "runToEntryPoint": "main",
            "svdFile": "${workspaceFolder}/STM32L476.svd"
        }
    ]
}